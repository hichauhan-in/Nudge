<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/nudge_widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_widget"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Top Row: Logo & App Name -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/widget_logo"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:contentDescription="Nudge Logo" />

        <TextView
            android:id="@+id/widget_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Nudge!"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:letterSpacing="0.05" />
    </LinearLayout>

    <!-- Support divider using FrameLayout since standard generic View tag is not on RemoteViews allowed list -->
    <FrameLayout
        android:id="@+id/widget_divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1FFFFFFF"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="10dp" />

    <!-- Centered Metric stats section (stretches and centers content as parent widget resizes) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="MINDFUL USAGE"
            android:textColor="#A5D6A7"
            android:textSize="11sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:letterSpacing="0.15" />

        <TextView
            android:id="@+id/widget_pauses_count"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="-- pauses"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:maxLines="1"
            android:autoSizeTextType="uniform"
            android:autoSizeMinTextSize="14sp"
            android:autoSizeMaxTextSize="38sp"
            android:layout_marginTop="6dp" />

        <TextView
            android:id="@+id/widget_savings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="-- minutes saved"
            android:textColor="#A5D6A7"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:maxLines="1"
            android:autoSizeTextType="uniform"
            android:autoSizeMinTextSize="10sp"
            android:autoSizeMaxTextSize="18sp"
            android:layout_marginTop="4dp" />

    </LinearLayout>

    <!-- Prompt instructions at bottom -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="TAP TO SEE BOUNDARIES"
        android:textColor="#66FFFFFF"
        android:layout_marginTop="8dp"
        android:textSize="10sp"
        android:fontFamily="monospace"
        android:letterSpacing="0.1" />

</LinearLayout>

